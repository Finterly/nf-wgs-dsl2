/*
* This configuration file is the default one used by the pipeline
*/

params {
	reads = "../data/*_R{1,2}*.fastq.gz"
	ref = "./genomes/Pf3D7_human.fa"
	refdir = "./genomes"
	outdir = "../results"
	refbed = "./genomes"
	rscript = "./run_quality_report.Rmd"
	trimadapter = "./adapters/TruSeq3-PE.fa"

    // Max resource options, defaults only, expecting to be overwritten
    max_memory      = '10.GB'       //'128.GB'
    max_cpus        = 4             //16
    max_threads     = 8             //'240.h'
    max_time        = '4.h'         //'240.h'
    sam_sort_memory = 10            //'240.h'

}

process {
    withLabel: big_mem {
        cpus = "${params.max_cpus}"
        memory = "${params.max_memory}"
        time = "${params.max_time}"
	    penv = 'smp' 
    }
}

profiles {
	conda {
		params.enable_conda = true
        docker.enabled = false
        singularity.enabled = false
        process.conda = "./envs/env.yml"
	}
	mamba {
		params.enable_conda = true
		conda.useMamba      = true
        docker.enabled      = false
        singularity.enabled = false
	}
    docker {
        params.enable_conda     = false
        docker.enabled          = true
        docker.userEmulation    = true
        singularity.enabled     = false
        process.container       = "conda/test:latest"
    }
    singularity {
        params.enable_conda     = false
        singularity.enabled     = true
        singularity.autoMounts  = true
        docker.enabled          = false
        process.container       = 'file://kn_workflow.sif'
    }
    sge {
        process {
            executor        = "sge"
            scratch         = true
            stageInMode     = "copy"
            stageOutMode    = "move"
            errorStrategy   = "retry"
	        clusterOptions = '-S /bin/bash -o job.log -e job.err'
        }
        executor {
	        queueSize = 1000
        }
    } 

}

manifest {
    name            = 'finterly/nf-wgs-dsl2'
    homePage        = 'https://github.com/finterly/nf-wgs-dsl2'
    description     = 'analysis pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=22.10.0'
    version         = '1.1.0'
}

// keep trace
trace {
	enabled = true
	file = "${params.outdir}/trace.txt"
    overwrite = true
}

// keep report
report {
	enabled = true
	file = "${params.outdir}/report.html"
    overwrite = true
}
